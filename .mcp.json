{
  "mcpServers": {
    "supabase": {
      "type": "http",
      "url": "https://mcp.supabase.com/mcp"
    },
    "chrome-devtools": {
      "type": "stdio",
      "command": "bunx",
      "args": ["chrome-devtools-mcp", "--browser-url=http://127.0.0.1:9222"],
      "env": {}
    },
    "playwright": {
      "type": "stdio",
      "command": "bunx",
      "args": [
        "@playwright/mcp",
        "--browser",
        "chromium",
        "--headless",
        "--viewport-size",
        "1280x720",
        "--user-data-dir",
        ".playwright-mcp"
      ],
      "env": {}
    }
  }
}
