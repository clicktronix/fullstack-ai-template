# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
!/coverage/README.md

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
.venv/

# Allow .env (shared defaults) to be committed
!.env.local.example
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

*storybook.log
/storybook-static/

# playwright mcp browser profile
.playwright-mcp

# MCP Configuration
!.mcp.json

# git worktrees
.worktrees/

.husky/

# E2E test artifacts
e2e/.auth/
e2e/test-results/
e2e/playwright-report/
test-results/
playwright-report/
.last-run.json
.env.test


# AI agents
.windsurf/
.agent/
.tmp/
.claude/projects/
.claude/scheduled_tasks.lock
.claude/settings.local.json

# Vercel agent-skills installs into .claude/skills via `npx skills add`.
# Track only bespoke project skills; generated installs stay local.
.claude/skills/vercel-react-best-practices/
.claude/skills/vercel-composition-patterns/
.claude/skills/web-design-guidelines/
