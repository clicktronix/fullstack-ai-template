{
  "name": "fullstack-ai-template",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "rm -rf .next && env -u NO_COLOR next build --webpack",
    "start": "next start",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "typecheck": "rm -rf .next tsconfig.tsbuildinfo && next typegen && mkdir -p .next/types && test -f .next/types/cache-life.d.ts || printf 'export {}\\n' > .next/types/cache-life.d.ts && tsc --noEmit --incremental false",
    "check": "bun run lint . && bun run typecheck && bun run format:check && bun run i18n:sync",
    "test": "bun test src/",
    "test:ci": "bun test src/ --max-concurrency=1",
    "test:watch": "bun test --watch src/",
    "test:coverage": "bun test --coverage --coverage-reporter=text --coverage-reporter=lcov src/",
    "test:coverage:text": "bun test --coverage --coverage-reporter=text src/",
    "test:coverage:lcov": "bun test --coverage --coverage-reporter=lcov src/",
    "test:e2e": "env -u NO_COLOR bunx playwright test --config e2e/playwright.config.ts",
    "bootstrap": "bun scripts/bootstrap-template.ts",
    "format": "eslint --fix; prettier --write .",
    "format:check": "prettier --check .",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "i18n:sync": "bun scripts/sync-translations.ts",
    "prepare": "husky",
    "gen:types": "export $(grep NEXT_PUBLIC_SUPABASE_URL .env.local | xargs) && supabase gen types typescript --project-id $(echo $NEXT_PUBLIC_SUPABASE_URL | sed 's|https://||' | sed 's|\\.supabase\\.co||') > src/adapters/supabase/types.ts"
  },
  "packageManager": "bun@1.3.8",
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@mantine/charts": "^8.3.16",
    "@mantine/core": "^8.3.14",
    "@mantine/form": "^8.3.14",
    "@mantine/hooks": "^8.3.14",
    "@mantine/modals": "^8.3.14",
    "@mantine/notifications": "^8.3.14",
    "@mantine/nprogress": "^8.3.18",
    "@sentry/nextjs": "^10.38.0",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.95.3",
    "@tabler/icons-react": "^3.36.1",
    "@tanstack/react-query": "5.90.2",
    "dayjs": "^1.11.19",
    "exceljs": "^4.4.0",
    "i18n-iso-countries": "^7.14.0",
    "libphonenumber-js": "^1.12.41",
    "next": "^16.1.6",
    "react": "^19.2.4",
    "react-diff-viewer-continued": "^4.2.0",
    "react-dom": "^19.2.4",
    "react-error-boundary": "^6.1.0",
    "react-intl": "^8.1.3",
    "react-markdown": "^10.1.0",
    "recharts": "2",
    "remark-gfm": "^4.0.1",
    "server-only": "^0.0.1",
    "valibot": "^1.2.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@happy-dom/global-registrator": "^20.6.1",
    "@playwright/test": "^1.58.2",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/nextjs-vite": "^10.3.5",
    "@tanstack/react-query-devtools": "5.90.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bun": "^1.3.9",
    "@types/node": "^25.2.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-sonarjs": "^3.0.7",
    "eslint-plugin-unicorn": "^62.0.0",
    "happy-dom": "^20.6.1",
    "husky": "^9.1.7",
    "knip": "^5.83.1",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "storybook": "^10.3.5",
    "typescript": "^5.9.3"
  }
}
