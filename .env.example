# Core application
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Production metadata requires NEXT_PUBLIC_SITE_URL unless Vercel provides
# VERCEL_PROJECT_PRODUCTION_URL / VERCEL_URL during deployment.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional monitoring
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=1
NEXT_PUBLIC_SENTRY_SEND_DEFAULT_PII=false
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Optional AI suggestions endpoint
# If omitted, the template uses a deterministic local fallback in the assistant panel.
AI_SUGGESTIONS_API_URL=
AI_SUGGESTIONS_API_KEY=

# Optional E2E credentials
# If omitted, the template runs anonymous access-control E2E checks only.
E2E_USER_EMAIL=
E2E_USER_PASSWORD=
